# Copy this file to .env and fill in the values for your Supabase project.
# Keep .env out of version control.

SUPABASE_PROJECT_ID="your-project-id"
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-public-anon-key"
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-public-anon-key"
VITE_AUTH_REDIRECT_URL="http://localhost:5173/"

# Optional: only required for server-side admin operations or RLS bypass.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# [DEPRECATED] Browser push notifications (VAPID) - replaced by 100% FCM migration.
